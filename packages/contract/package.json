    "@ewm/core-status": "workspace:*",
    "@ewm/map-core": "workspace:*",
    "@ewm/places": "workspace:*",
    "@ewm/sources": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
