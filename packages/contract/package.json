{
  "name": "@ewm/contract",
  "version": "0.1.0",
  "private": true,
  "description": "THE hazard module contract: the TypeScript interfaces every EWM hazard module implements and the platform context it registers against.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
